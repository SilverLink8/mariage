  <!----------------------------------------------------------------- FORMULAIRE ------------------------------------------->
<section id="rsvp" class="section-cream">

  <h2>RSVP</h2>

  <p>
    Merci de confirmer votre présence avant le 1er juin 2027.
  </p>

  <form id="rsvpForm" action="TON_URL_GOOGLE_SCRIPT" method="POST">

    <label for="respondant">
      Nom et prénom de la personne qui répond au formulaire
    </label>

    <input
      type="text"
      id="respondant"
      name="Respondant"
      required
    >

    <label for="email">
      Adresse e-mail
    </label>

    <input
      type="email"
      id="email"
      name="Email"
      required
    >

    <label for="presence">
      Serez-vous présent ?
    </label>

    <select id="presence" name="Présence" required>
      <option value="">Choisir...</option>
      <option value="Oui">Oui</option>
      <option value="Non">Non</option>
    </select>


    <div id="presenceOui" class="cache">

      <label for="adultes">
        Nombre d'adultes
      </label>

      <input
        type="number"
        id="adultes"
        min="0"
        value="1"
      >

      <div id="adultesContainer"></div>


      <label for="enfants">
        Nombre d'enfants
      </label>

      <input
        type="number"
        id="enfants"
        min="0"
        value="0"
      >

      <div id="enfantsContainer"></div>


    </div>


    <div id="commentaireBloc">

      <label for="commentaire">
        Un commentaire ou une précision ? (facultatif)
      </label>

      <textarea
        id="commentaire"
        name="Commentaire"
        rows="4"
      ></textarea>

    </div>


    <button type="submit" class="bouton">
      Envoyer ma réponse
    </button>

  </form>


  <div id="merci" class="cache">

    <h3>Merci beaucoup</h3>

    <p id="messageMerci"></p>

  </div>


</section>
  
